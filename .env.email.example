# Email Service Configuration
# Copy this file to .env and fill in your values

# Enable/Disable Email Service
EMAIL_ENABLED=true

# Gmail Configuration (Recommended for Development)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# From Email Address
EMAIL_FROM=noreply@urlshortener.com

# Frontend Base URL (for reset links)
APP_BASE_URL=http://localhost:5173

# ============================================
# How to Get Gmail App Password:
# ============================================
# 1. Go to: https://myaccount.google.com/security
# 2. Enable "2-Step Verification"
# 3. Go to: https://myaccount.google.com/apppasswords
# 4. Select "Mail" and "Other (Custom name)"
# 5. Name it: "Shortly URL Shortener"
# 6. Click "Generate"
# 7. Copy the 16-character password
# 8. Paste it in MAIL_PASSWORD above

# ============================================
# Alternative Email Providers:
# ============================================

# Outlook/Hotmail
# MAIL_HOST=smtp-mail.outlook.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@outlook.com
# MAIL_PASSWORD=your-password

# Yahoo
# MAIL_HOST=smtp.mail.yahoo.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@yahoo.com
# MAIL_PASSWORD=your-app-password

# SendGrid (Production)
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your-sendgrid-api-key

# AWS SES (Production)
# MAIL_HOST=email-smtp.us-east-1.amazonaws.com
# MAIL_PORT=587
# MAIL_USERNAME=your-aws-access-key
# MAIL_PASSWORD=your-aws-secret-key
